# ── Shared build: install + compile all common packages ──────────────────────
# No ARG dependency in this stage — Docker caches it across all agent builds.
FROM node:22-alpine AS shared-build
WORKDIR /app

COPY package.json ./
COPY tsconfig.base.json ./
COPY packages/shared ./packages/shared
COPY packages/lean-index ./packages/lean-index
COPY packages/agent-facts ./packages/agent-facts
COPY packages/agents/shared ./packages/agents/shared

RUN npm install --workspaces --if-present
RUN npm run build --workspace packages/shared
RUN npm run build --workspace packages/lean-index
RUN npm run build --workspace packages/agent-facts
RUN npm run build --workspace packages/agents/shared

# ── Agent build: compile the scenario-specific agent package ─────────────────
FROM shared-build AS agent-build
ARG AGENT_PKG

COPY packages/agents/${AGENT_PKG} ./packages/agents/${AGENT_PKG}
RUN npm install --workspaces --if-present
RUN npm run build --workspace packages/agents/${AGENT_PKG}

# ── Runtime ───────────────────────────────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app
ARG AGENT_PKG
ENV AGENT_PKG=${AGENT_PKG}

COPY --from=agent-build /app/package.json ./
COPY --from=agent-build /app/node_modules ./node_modules
COPY --from=agent-build /app/packages/shared/dist ./packages/shared/dist
COPY --from=agent-build /app/packages/shared/package.json ./packages/shared/
COPY --from=agent-build /app/packages/lean-index/dist ./packages/lean-index/dist
COPY --from=agent-build /app/packages/lean-index/package.json ./packages/lean-index/
COPY --from=agent-build /app/packages/agent-facts/dist ./packages/agent-facts/dist
COPY --from=agent-build /app/packages/agent-facts/package.json ./packages/agent-facts/
COPY --from=agent-build /app/packages/agents/shared/dist ./packages/agents/shared/dist
COPY --from=agent-build /app/packages/agents/shared/package.json ./packages/agents/shared/
COPY --from=agent-build /app/packages/agents/${AGENT_PKG}/dist ./packages/agents/${AGENT_PKG}/dist
COPY --from=agent-build /app/packages/agents/${AGENT_PKG}/package.json ./packages/agents/${AGENT_PKG}/

# exec replaces the shell so node is PID 1 and receives signals correctly.
CMD ["sh", "-c", "exec node packages/agents/$AGENT_PKG/dist/server-entry.js"]
